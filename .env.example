# Location for Open-Meteo
LATITUDE=40.7128
LONGITUDE=-74.0060
TIMEZONE=auto

# Optional location lookup methods (used before LAT/LON fallback)
# 1) ZIP + country (recommended for US ZIP code workflows)
ZIP_CODE=
COUNTRY_CODE=US

# 2) Neighborhood/city query (example: "Greenpoint Brooklyn")
LOCATION_QUERY=

# Display update interval
REFRESH_SECONDS=600

# Sensor mode: dht22 or simulated
SENSOR_MODE=simulated

# DHT22 data pins (BCM numbering), comma-separated
# Keep these separate from display SPI/control pins.
DHT22_GPIO_PINS=4,27

# Optional backward-compatible single-pin settings (used if DHT22_GPIO_PINS is empty)
DHT22_GPIO_PIN=4
DHT22_GPIO_PIN_2=27

# Sanity filters for apartment indoor readings
MIN_VALID_TEMP_F=20
MAX_VALID_TEMP_F=95
MIN_VALID_HUMIDITY_PCT=5
MAX_VALID_HUMIDITY_PCT=100

# Optional: display rotation if your panel backend supports it
DISPLAY_ROTATION=0
